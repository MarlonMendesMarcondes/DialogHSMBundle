{% extends '@MauticCore/Default/content.html.twig' %}
{% block mauticContent %}dialoghsm_dashboard{% endblock %}
{% block headerTitle %}{{ 'dialoghsm.dashboard.title'|trans }}{% endblock %}

{% block content %}
<style>
.dialoghsm-card-label { font-size: 11px; margin-top: 4px; color: var(--text-helper); }
</style>
<div class="row" style="margin-bottom: 20px;">
    <div class="col-xs-12" style="display: flex; flex-wrap: wrap; gap: 8px;">
        <a href="{{ path('mautic_dialoghsm_log_index') }}" class="btn btn-secondary btn-sm">
            <i class="ri-list-unordered"></i> {{ 'dialoghsm.menu.logs'|trans }}
        </a>
        <a href="{{ path('mautic_dialoghsm_number_index') }}" class="btn btn-secondary btn-sm">
            <i class="ri-phone-line"></i> {{ 'dialoghsm.menu.numbers'|trans }}
        </a>
    </div>
</div>

{# ── Últimas 24h ── #}
<h4 class="text-muted" style="margin: 0 0 12px;">{{ 'dialoghsm.dashboard.period.24h'|trans }}</h4>
<div class="row" style="margin-bottom: 24px;">
    {{ _self.statCard('dialoghsm.dashboard.total',  stats24h.total,  'ri-send-plane-line',      '#555') }}
    {{ _self.statCard('dialoghsm.dashboard.queued', stats24h.queued, 'ri-time-line',             '#888') }}
    {{ _self.statCard('dialoghsm.dashboard.sent',   stats24h.sent,   'ri-checkbox-circle-line',  '#5cb85c') }}
    {{ _self.statCard('dialoghsm.dashboard.failed', stats24h.failed, 'ri-close-circle-line',     '#d9534f') }}
    {{ _self.statCard('dialoghsm.dashboard.dlq',    stats24h.dlq,    'ri-error-warning-line',    '#f0ad4e') }}
    {% set processed24h = stats24h.sent + stats24h.failed + stats24h.dlq %}
    {% if processed24h > 0 %}
        {% set rate = (stats24h.sent / processed24h * 100)|round(1) %}
    {% else %}
        {% set rate = 0 %}
    {% endif %}
    {{ _self.rateCard('dialoghsm.dashboard.success_rate', rate, rate >= 90 ? '#5cb85c' : (rate >= 70 ? '#f0ad4e' : '#d9534f')) }}
</div>

{# ── Últimos 7 dias ── #}
<h4 class="text-muted" style="margin: 0 0 12px;">{{ 'dialoghsm.dashboard.period.7d'|trans }}</h4>
<div class="row" style="margin-bottom: 32px;">
    {{ _self.statCard('dialoghsm.dashboard.total',  stats7d.total,  'ri-send-plane-line',      '#555') }}
    {{ _self.statCard('dialoghsm.dashboard.queued', stats7d.queued, 'ri-time-line',             '#888') }}
    {{ _self.statCard('dialoghsm.dashboard.sent',   stats7d.sent,   'ri-checkbox-circle-line',  '#5cb85c') }}
    {{ _self.statCard('dialoghsm.dashboard.failed', stats7d.failed, 'ri-close-circle-line', '#d9534f') }}
    {{ _self.statCard('dialoghsm.dashboard.dlq', stats7d.dlq, 'ri-error-warning-line', '#f0ad4e') }}
    {% set processed7d = stats7d.sent + stats7d.failed + stats7d.dlq %}
    {% if processed7d > 0 %}
        {% set rate7 = (stats7d.sent / processed7d * 100)|round(1) %}
    {% else %}
        {% set rate7 = 0 %}
    {% endif %}
    {{ _self.rateCard('dialoghsm.dashboard.success_rate', rate7, rate7 >= 90 ? '#5cb85c' : (rate7 >= 70 ? '#f0ad4e' : '#d9534f')) }}
</div>

{# ── Gráfico ── #}
<div class="panel panel-default">
    <div class="panel-heading" style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px;">
        <h3 class="panel-title" style="margin: 0;">{{ 'dialoghsm.dashboard.chart.title'|trans }}</h3>
        <div class="btn-group btn-group-xs" role="group">
            <a href="{{ path('mautic_dialoghsm_dashboard', {days: 7}) }}"
               class="btn {{ chartDays == 7 ? 'btn-primary' : 'btn-default' }}">7d</a>
            <a href="{{ path('mautic_dialoghsm_dashboard', {days: 14}) }}"
               class="btn {{ chartDays == 14 ? 'btn-primary' : 'btn-default' }}">14d</a>
            <a href="{{ path('mautic_dialoghsm_dashboard', {days: 30}) }}"
               class="btn {{ chartDays == 30 ? 'btn-primary' : 'btn-default' }}">30d</a>
        </div>
    </div>
    <div class="panel-body">
        <div style="position: relative; height: 320px;">
            <canvas id="dialoghsm-chart"></canvas>
        </div>
    </div>
</div>

<script>
(function () {
    var chartData = {{ chartJson|raw }};

    var labelMap = {
        queued: '{{ 'dialoghsm.log.status.queued'|trans }}',
        sent:   '{{ 'dialoghsm.log.status.sent'|trans }}',
        failed: '{{ 'dialoghsm.log.status.failed'|trans }}',
        dlq:    '{{ 'dialoghsm.log.status.dlq'|trans }}'
    };

    chartData.datasets.forEach(function (ds) {
        ds.label = labelMap[ds.label] || ds.label;
    });

    var ctx = document.getElementById('dialoghsm-chart').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: chartData,
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                x: {
                    stacked: true,
                    grid: { display: false },
                    ticks: { maxRotation: 45 }
                },
                y: {
                    stacked: true,
                    beginAtZero: true,
                    ticks: {
                        precision: 0,
                        callback: function (v) { return v.toLocaleString(); }
                    },
                    grid: { color: 'rgba(0,0,0,0.06)' }
                }
            },
            plugins: {
                legend: { position: 'bottom', labels: { boxWidth: 14, padding: 16 } },
                tooltip: {
                    mode: 'index',
                    intersect: false,
                    callbacks: {
                        footer: function (items) {
                            var total = items.reduce(function (sum, i) { return sum + i.parsed.y; }, 0);
                            return '{{ 'dialoghsm.dashboard.total'|trans }}: ' + total.toLocaleString();
                        }
                    }
                }
            }
        }
    });
})();
</script>
{% endblock %}

{% macro statCard(labelKey, value, icon, color) %}
<div class="col-xs-6 col-sm-4 col-md-2" style="margin-bottom: 12px;">
    <div class="panel panel-default" style="margin-bottom: 0; text-align: center; padding: 16px 8px;">
        <i class="{{ icon }}" style="font-size: 24px; color: {{ color }};"></i>
        <div style="font-size: 28px; font-weight: bold; color: {{ color }}; line-height: 1.2;">{{ value }}</div>
        <div class="dialoghsm-card-label">{{ labelKey|trans }}</div>
    </div>
</div>
{% endmacro %}

{% macro rateCard(labelKey, value, color) %}
<div class="col-xs-6 col-sm-4 col-md-2" style="margin-bottom: 12px;">
    <div class="panel panel-default" style="margin-bottom: 0; text-align: center; padding: 16px 8px;">
        <i class="ri-percent-line" style="font-size: 24px; color: {{ color }};"></i>
        <div style="font-size: 28px; font-weight: bold; color: {{ color }}; line-height: 1.2;">{{ value }}%</div>
        <div class="dialoghsm-card-label">{{ labelKey|trans }}</div>
    </div>
</div>
{% endmacro %}
