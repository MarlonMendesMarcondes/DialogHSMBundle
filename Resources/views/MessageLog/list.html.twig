{% set isIndex = tmpl == 'index' ? true : false %}
{% set tmpl = 'list' %}
{% extends isIndex ? '@MauticCore/Default/content.html.twig' : '@MauticCore/Default/raw_output.html.twig' %}
{% block mauticContent %}dialoghsm_log{% endblock %}
{% block headerTitle %}{{ 'dialoghsm.log.list.title'|trans }}{% endblock %}
{% block content %}
    {% if isIndex %}
    <div id="page-list-wrapper" class="panel panel-default">
        <div class="page-list-header">
            <div class="list-toolbar-container">
                <div class="toolbar-action-buttons">
                    <span class="label label-default" style="font-size:13px; padding: 6px 12px;">
                        {{ totalItems }} / {{ maxLogs }} {{ 'dialoghsm.log.list.counter'|trans }}
                    </span>
                </div>
            </div>
        </div>

        {# ── Barra de Filtros ── #}
        <div class="page-list-filter" style="padding: 10px 15px; background: var(--layer-01); border-bottom: 1px solid var(--border-subtle-01);">
            <form method="post" action="{{ path('mautic_dialoghsm_log_index') }}" class="form-inline" id="dialoghsm-log-filter-form">
                <div class="form-group" style="margin-right: 8px;">
                    <label class="sr-only" for="filter-status">{{ 'dialoghsm.log.filter.status'|trans }}</label>
                    <select name="dialoghsm_log_filter[status]" id="filter-status" class="form-control input-sm">
                        <option value="">{{ 'dialoghsm.log.filter.status.all'|trans }}</option>
                        {% for s in ['queued', 'sent', 'failed', 'dlq'] %}
                            <option value="{{ s }}" {% if (filters.status ?? '') == s %}selected{% endif %}>{{ ('dialoghsm.log.status.' ~ s)|trans }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group" style="margin-right: 8px;">
                    <label class="sr-only" for="filter-date-from">{{ 'dialoghsm.log.filter.date_from'|trans }}</label>
                    <input type="date" name="dialoghsm_log_filter[dateFrom]" id="filter-date-from"
                           class="form-control input-sm"
                           placeholder="{{ 'dialoghsm.log.filter.date_from'|trans }}"
                           value="{{ filters.dateFrom ?? '' }}">
                </div>

                <div class="form-group" style="margin-right: 8px;">
                    <label class="sr-only" for="filter-date-to">{{ 'dialoghsm.log.filter.date_to'|trans }}</label>
                    <input type="date" name="dialoghsm_log_filter[dateTo]" id="filter-date-to"
                           class="form-control input-sm"
                           placeholder="{{ 'dialoghsm.log.filter.date_to'|trans }}"
                           value="{{ filters.dateTo ?? '' }}">
                </div>

                <div class="form-group" style="margin-right: 8px;">
                    <label class="sr-only" for="filter-sender">{{ 'dialoghsm.log.filter.sender'|trans }}</label>
                    <select name="dialoghsm_log_filter[senderName]" id="filter-sender" class="form-control input-sm">
                        <option value="">{{ 'dialoghsm.log.filter.sender'|trans }}</option>
                        {% for name in senderNames %}
                            <option value="{{ name }}" {% if (filters.senderName ?? '') == name %}selected{% endif %}>{{ name }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group" style="margin-right: 8px;">
                    <label class="sr-only" for="filter-contact">{{ 'dialoghsm.log.filter.contact'|trans }}</label>
                    <input type="text" name="dialoghsm_log_filter[contact]" id="filter-contact"
                           class="form-control input-sm"
                           placeholder="{{ 'dialoghsm.log.filter.contact'|trans }}"
                           value="{{ filters.contact ?? '' }}"
                           style="width: 160px;">
                </div>

                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="ri-search-line"></i> {{ 'dialoghsm.log.filter.apply'|trans }}
                </button>

                {% if filters is not empty %}
                    <a href="{{ path('mautic_dialoghsm_log_index') }}?clearFilters=1"
                       class="btn btn-secondary btn-sm" style="margin-left: 4px;">
                        <i class="ri-close-line"></i> {{ 'dialoghsm.log.filter.clear'|trans }}
                    </a>
                {% endif %}
            </form>
        </div>

        <div class="page-list">
            {{ block('listResults') }}
        </div>
    </div>
    {% else %}
        {{ block('listResults') }}
    {% endif %}
{% endblock %}

{% block listResults %}
{% if items|length %}
    <div class="table-responsive">
        <table class="table table-hover dialoghsm-log-list">
            <thead>
            <tr>
                <th class="col-dialoghsm-date">{{ 'dialoghsm.log.date_sent'|trans }}</th>
                <th class="col-dialoghsm-sender">{{ 'dialoghsm.log.sender'|trans }}</th>
                <th class="col-dialoghsm-lead">{{ 'dialoghsm.log.lead_id'|trans }}</th>
                <th class="col-dialoghsm-phone">{{ 'dialoghsm.log.phone'|trans }}</th>
                <th class="col-dialoghsm-template">{{ 'dialoghsm.log.template'|trans }}</th>
                <th class="col-dialoghsm-campaign">{{ 'dialoghsm.log.campaign'|trans }}</th>
                <th class="col-dialoghsm-status">{{ 'dialoghsm.log.status'|trans }}</th>
                <th class="col-dialoghsm-http">HTTP</th>
                <th class="col-dialoghsm-error">{{ 'dialoghsm.log.error'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for item in items %}
                <tr>
                    <td>{{ item.getDateSent()|date('d/m/Y H:i:s', timezone) }}</td>
                    <td>{{ item.getSenderName() ?? '—' }}</td>
                    <td>
                        <a href="{{ path('mautic_contact_action', {'objectAction': 'view', 'objectId': item.getLeadId()}) }}" target="_blank">
                            #{{ item.getLeadId() }}
                        </a>
                    </td>
                    <td>{{ item.getPhoneNumber() }}</td>
                    <td>{{ item.getTemplateName() }}</td>
                    <td>
                        {% if item.getCampaignId() is not null %}
                            <a href="{{ path('mautic_campaign_action', {'objectAction': 'view', 'objectId': item.getCampaignId()}) }}" target="_blank">
                                #{{ item.getCampaignId() }}
                            </a>
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if item.getStatus() == 'queued' %}
                            <span class="label label-default">{{ 'dialoghsm.log.status.queued'|trans }}</span>
                        {% elseif item.getStatus() == 'sent' %}
                            <span class="label label-success">{{ 'dialoghsm.log.status.sent'|trans }}</span>
                        {% elseif item.getStatus() == 'delivered' %}
                            <span class="label label-info">{{ 'dialoghsm.log.status.delivered'|trans }}</span>
                        {% elseif item.getStatus() == 'read' %}
                            <span class="label label-primary">{{ 'dialoghsm.log.status.read'|trans }}</span>
                        {% elseif item.getStatus() == 'dlq' %}
                            <span class="label label-warning">{{ 'dialoghsm.log.status.dlq'|trans }}</span>
                        {% else %}
                            <span class="label label-danger">{{ ('dialoghsm.log.status.' ~ item.getStatus())|trans }}</span>
                        {% endif %}
                    </td>
                    <td>
                        {% set http = item.getHttpStatusCode() %}
                        {% if http is not null %}
                            {% if http >= 200 and http < 300 %}
                                <span class="label label-success">{{ http }}</span>
                            {% else %}
                                <span class="label label-danger">{{ http }}</span>
                            {% endif %}
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if item.getErrorMessage() is not empty %}
                            <span class="text-danger" title="{{ item.getErrorMessage() }}">
                                {{ item.getErrorMessage()|length > 80 ? item.getErrorMessage()|slice(0, 80) ~ '…' : item.getErrorMessage() }}
                            </span>
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="panel-footer">
        {{- include('@MauticCore/Helper/pagination.html.twig', {
            'totalItems' : totalItems,
            'page'       : page,
            'limit'      : limit,
            'baseUrl'    : path('mautic_dialoghsm_log_index'),
            'sessionVar' : 'dialoghsm.log',
        }) -}}
    </div>
{% else %}
    {{- include('@MauticCore/Helper/noresults.html.twig', {'message' : 'dialoghsm.log.noresults'}) -}}
{% endif %}
{% endblock %}
